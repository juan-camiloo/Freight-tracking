{
  "expo": {
    "name": "freight-tracking",
    "slug": "freight-tracking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./visual/logo3.jpeg",
    "scheme": "freighttracking",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "intentFilters": [{
        "action": "VIEW",
        "autoVerify": true,
        "data":[{
            "scheme": "freighttracking"
          }
        ],
        "category":["BROWSABLE", "DEFAULT"]
      }],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./visual/logo2.png",
        "monochromeImage": "./visual/logo2.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ingelox26.freighttracking",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "single",
      "favicon": "./visual/logo3.jpeg"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1ad596bc-ed84-4640-a1fb-fed5ba14dacf"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1ad596bc-ed84-4640-a1fb-fed5ba14dacf"
    }
  }
}
